---
interface Props {
	title?: string;
}

const { title = 'Presentation' } = Astro.props;
---

<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
</head>
<body>
  <div class="presenter-viewport">
    <div class="slide-scaler">
      <slot />
    </div>
  </div>
  <div class="presenter-progress" data-presenter-ui>
    <div class="presenter-progress-bar" data-progress-bar></div>
  </div>
  <div class="slide-counter" data-slide-counter data-presenter-ui></div>
  <div class="presenter-notes" data-presenter-notes data-presenter-ui></div>
  <script>
    import { SlidePresenter } from '../presenter/presenter';
    import { setupScaling } from '../presenter/scale';

    setupScaling();
    new SlidePresenter();
  </script>
</body>
</html>

<style is:global>
  *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
  html, body { width: 100vw; height: 100vh; overflow: hidden; background: #000; }

  .presenter-viewport {
    width: 100vw;
    height: 100vh;
    overflow: hidden;
    position: relative;
  }

  .slide-scaler {
    position: absolute;
    top: 0;
    left: 0;
    transform-origin: top left;
  }

  /* ===== Slide visibility & transitions ===== */
  .slide-scaler > [data-slide] {
    position: absolute;
    inset: 0;
    z-index: 0;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.4s ease;
  }

  .slide-scaler > [data-slide].active {
    z-index: 1;
    opacity: 1;
    pointer-events: auto;
  }

  /* ===== Progress bar ===== */
  .presenter-progress {
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: transparent;
    z-index: 1000;
  }

  .presenter-progress-bar {
    height: 100%;
    background: #2563eb;
    transition: width 0.3s ease;
    width: 0%;
  }

  /* ===== Slide counter ===== */
  .slide-counter {
    position: fixed;
    bottom: 12px;
    right: 16px;
    font-size: 14px;
    color: rgba(255, 255, 255, 0.5);
    font-family: system-ui, sans-serif;
    z-index: 1000;
    pointer-events: none;
  }

  /* ===== Presenter notes ===== */
  .presenter-notes {
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    height: 200px;
    background: rgba(0, 0, 0, 0.9);
    color: white;
    padding: 16px;
    font-size: 18px;
    font-family: system-ui, sans-serif;
    overflow-y: auto;
    transform: translateY(100%);
    transition: transform 0.3s ease;
    z-index: 999;
  }

  .presenter-notes.visible {
    transform: translateY(0);
  }
</style>
