---
import SlideLayout from '../../../components/SlideLayout.astro';
---

<SlideLayout
  title="The Problem"
  pageNumber={3}
  transition="fade"
  notes="Pause here. Let the audience absorb the number before explaining."
>
  <div class="problem">
    <div class="stat-block">
      <span class="big-number">79%</span>
      <p class="stat-label">of audiences lose attention<br />within the first 10 slides</p>
    </div>
    <div class="explanation">
      <p>The issue isn't the content — it's the delivery. Dense slides with competing messages force the audience to read instead of listen.</p>
      <p class="source">Source: Prezi State of Attention Report, 2024</p>
    </div>
  </div>
</SlideLayout>

<style>
  .problem {
    display: flex;
    flex-direction: column;
    justify-content: center;
    height: 100%;
    gap: var(--space-xl);
  }

  .stat-block {
    text-align: center;
  }

  .big-number {
    font-size: 160px;
    font-weight: 800;
    color: var(--color-primary);
    line-height: 1;
    display: block;
    margin-bottom: var(--space-md);
  }

  .stat-label {
    font-size: var(--font-size-heading);
    color: var(--color-text);
    line-height: 1.4;
  }

  .explanation {
    text-align: center;
    max-width: 900px;
    margin: 0 auto;
  }

  .explanation p {
    font-size: var(--font-size-body);
    color: var(--color-muted);
    line-height: 1.6;
  }

  .source {
    font-size: var(--font-size-caption);
    color: var(--color-muted);
    margin-top: var(--space-md);
  }
</style>
