---
import SlideLayout from '../../../components/SlideLayout.astro';
---

<SlideLayout
  showHeader={false}
  showFooter={false}
  transition="fade"
  notes="Opening. Start with a company introduction."
>
  <div class="title-slide">
    <h1>Effective Presentations</h1>
    <p class="subtitle">Principles for slides that communicate</p>
  </div>
</SlideLayout>

<style>
  .title-slide {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    height: 100%;
    text-align: center;
  }

  h1 {
    font-size: var(--font-size-title);
    font-weight: 700;
    color: var(--color-primary);
    margin-bottom: var(--space-lg);
  }

  .subtitle {
    font-size: var(--font-size-heading);
    color: var(--color-muted);
  }
</style>
