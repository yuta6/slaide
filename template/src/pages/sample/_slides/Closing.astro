---
import SlideLayout from '../../../components/SlideLayout.astro';
---

<SlideLayout
  showHeader={false}
  showFooter={false}
  transition="fade"
  notes="Thank the audience. Open for questions."
>
  <div class="closing">
    <h1>Make Every Slide Count</h1>
    <p class="tagline">Built with slaide</p>
  </div>
</SlideLayout>

<style>
  .closing {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    height: 100%;
    text-align: center;
    gap: var(--space-lg);
  }

  h1 {
    font-size: var(--font-size-title);
    font-weight: 700;
    color: var(--color-text);
    line-height: 1.2;
  }

  .tagline {
    font-size: var(--font-size-body);
    color: var(--color-muted);
  }
</style>
