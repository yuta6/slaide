---
import SlideLayout from '../../../components/SlideLayout.astro';
---

<SlideLayout
  title="Process"
  pageNumber={7}
  transition="fade"
  notes="Walk through each step sequentially. Emphasize that each step builds on the previous one."
>
  <div class="process">
    <h2>From Idea to Impact</h2>
    <div class="steps">
      <div class="step">
        <div class="step-icon">
          <svg viewBox="0 0 48 48" xmlns="http://www.w3.org/2000/svg">
            <circle cx="24" cy="24" r="20" fill="none" stroke="var(--color-chart-1)" stroke-width="3"/>
            <text x="24" y="30" text-anchor="middle" fill="var(--color-chart-1)" font-size="20" font-weight="700">1</text>
          </svg>
        </div>
        <span class="step-title">Research</span>
        <span class="step-desc">Gather data and understand your audience</span>
      </div>
      <div class="arrow">
        <svg viewBox="0 0 40 24" xmlns="http://www.w3.org/2000/svg">
          <line x1="0" y1="12" x2="32" y2="12" stroke="var(--color-border)" stroke-width="2"/>
          <polygon points="30,6 40,12 30,18" fill="var(--color-border)"/>
        </svg>
      </div>
      <div class="step">
        <div class="step-icon">
          <svg viewBox="0 0 48 48" xmlns="http://www.w3.org/2000/svg">
            <circle cx="24" cy="24" r="20" fill="none" stroke="var(--color-chart-2)" stroke-width="3"/>
            <text x="24" y="30" text-anchor="middle" fill="var(--color-chart-2)" font-size="20" font-weight="700">2</text>
          </svg>
        </div>
        <span class="step-title">Structure</span>
        <span class="step-desc">One message per slide, clear hierarchy</span>
      </div>
      <div class="arrow">
        <svg viewBox="0 0 40 24" xmlns="http://www.w3.org/2000/svg">
          <line x1="0" y1="12" x2="32" y2="12" stroke="var(--color-border)" stroke-width="2"/>
          <polygon points="30,6 40,12 30,18" fill="var(--color-border)"/>
        </svg>
      </div>
      <div class="step">
        <div class="step-icon">
          <svg viewBox="0 0 48 48" xmlns="http://www.w3.org/2000/svg">
            <circle cx="24" cy="24" r="20" fill="none" stroke="var(--color-chart-3)" stroke-width="3"/>
            <text x="24" y="30" text-anchor="middle" fill="var(--color-chart-3)" font-size="20" font-weight="700">3</text>
          </svg>
        </div>
        <span class="step-title">Design</span>
        <span class="step-desc">Apply visual principles and whitespace</span>
      </div>
      <div class="arrow">
        <svg viewBox="0 0 40 24" xmlns="http://www.w3.org/2000/svg">
          <line x1="0" y1="12" x2="32" y2="12" stroke="var(--color-border)" stroke-width="2"/>
          <polygon points="30,6 40,12 30,18" fill="var(--color-border)"/>
        </svg>
      </div>
      <div class="step">
        <div class="step-icon">
          <svg viewBox="0 0 48 48" xmlns="http://www.w3.org/2000/svg">
            <circle cx="24" cy="24" r="20" fill="none" stroke="var(--color-chart-4)" stroke-width="3"/>
            <text x="24" y="30" text-anchor="middle" fill="var(--color-chart-4)" font-size="20" font-weight="700">4</text>
          </svg>
        </div>
        <span class="step-title">Deliver</span>
        <span class="step-desc">Present with confidence and clarity</span>
      </div>
    </div>
  </div>
</SlideLayout>

<style>
  .process {
    display: flex;
    flex-direction: column;
    height: 100%;
    padding-top: var(--space-lg);
  }

  h2 {
    font-size: var(--font-size-heading);
    font-weight: 700;
    color: var(--color-text);
    margin-bottom: var(--space-xl);
  }

  .steps {
    display: flex;
    align-items: center;
    justify-content: center;
    flex: 1;
    gap: var(--space-md);
  }

  .step {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: var(--space-sm);
    padding: var(--space-lg);
    background: var(--color-bg);
    border: 2px solid var(--color-border);
    border-radius: 16px;
    flex: 1;
    max-width: 320px;
  }

  .step-icon {
    width: 48px;
    height: 48px;
  }

  .step-title {
    font-size: var(--font-size-body);
    font-weight: 600;
    color: var(--color-text);
  }

  .step-desc {
    font-size: var(--font-size-caption);
    color: var(--color-muted);
    line-height: 1.5;
  }

  .arrow {
    width: 40px;
    flex-shrink: 0;
  }
</style>
