---
import SlideLayout from '../../../components/SlideLayout.astro';
---

<SlideLayout
  title="Before & After"
  pageNumber={5}
  transition="fade"
  notes="Walk through the left side first, ask what's wrong. Then reveal the right side."
>
  <div class="comparison">
    <h2>Applying the Principles</h2>
    <div class="columns">
      <div class="column before">
        <span class="label label-before">Before</span>
        <div class="mock-slide">
          <div class="mock-title">Q3 Results Summary & Analysis for All Regions Including Forecast</div>
          <div class="mock-body">
            <div class="mock-line w100"></div>
            <div class="mock-line w90"></div>
            <div class="mock-line w95"></div>
            <div class="mock-line w80"></div>
            <div class="mock-line w100"></div>
            <div class="mock-line w85"></div>
            <div class="mock-line w70"></div>
            <div class="mock-line w90"></div>
            <div class="mock-line w95"></div>
            <div class="mock-line w60"></div>
          </div>
        </div>
        <p class="caption">Too many messages, no visual hierarchy, wall of text</p>
      </div>
      <div class="column after">
        <span class="label label-after">After</span>
        <div class="mock-slide clean">
          <div class="mock-title-clean">Revenue grew 24% in Q3</div>
          <div class="mock-chart">
            <div class="bar" style="height: 40%"></div>
            <div class="bar" style="height: 55%"></div>
            <div class="bar" style="height: 65%"></div>
            <div class="bar highlight" style="height: 85%"></div>
          </div>
        </div>
        <p class="caption">One message, clear hierarchy, data speaks</p>
      </div>
    </div>
  </div>
</SlideLayout>

<style>
  .comparison {
    display: flex;
    flex-direction: column;
    height: 100%;
    padding-top: var(--space-lg);
  }

  h2 {
    font-size: var(--font-size-heading);
    font-weight: 700;
    color: var(--color-text);
    margin-bottom: var(--space-lg);
  }

  .columns {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-xl);
    flex: 1;
  }

  .column {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  .label {
    font-size: var(--font-size-caption);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  .label-before { color: var(--color-muted); }
  .label-after { color: var(--color-primary); }

  /* Mock "bad" slide */
  .mock-slide {
    background: #f3f4f6;
    border-radius: 8px;
    padding: var(--space-lg);
    flex: 1;
  }

  .mock-title {
    font-size: 14px;
    font-weight: 700;
    color: var(--color-text);
    margin-bottom: var(--space-md);
    line-height: 1.3;
  }

  .mock-line {
    height: 8px;
    background: #d1d5db;
    border-radius: 4px;
    margin-bottom: 6px;
  }

  .w100 { width: 100%; }
  .w95 { width: 95%; }
  .w90 { width: 90%; }
  .w85 { width: 85%; }
  .w80 { width: 80%; }
  .w70 { width: 70%; }
  .w60 { width: 60%; }

  /* Mock "good" slide */
  .mock-slide.clean {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
  }

  .mock-title-clean {
    font-size: 18px;
    font-weight: 700;
    color: var(--color-primary);
  }

  .mock-chart {
    display: flex;
    align-items: flex-end;
    gap: var(--space-lg);
    height: 60%;
    padding-top: var(--space-lg);
  }

  .bar {
    flex: 1;
    background: var(--color-border);
    border-radius: 4px 4px 0 0;
  }

  .bar.highlight {
    background: var(--color-primary);
  }

  .caption {
    font-size: var(--font-size-caption);
    color: var(--color-muted);
    text-align: center;
  }
</style>
