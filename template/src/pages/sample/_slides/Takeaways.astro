---
import SlideLayout from '../../../components/SlideLayout.astro';
---

<SlideLayout
  title="Summary"
  pageNumber={7}
  transition="fade"
  notes="Recap the three principles. End with a clear call to action: apply these to your next deck."
>
  <div class="takeaways">
    <h2>Key Takeaways</h2>
    <ul class="takeaway-list">
      <li>
        <div class="check">&#10003;</div>
        <div>
          <strong>One slide, one message</strong>
          <p>If you can't summarize the slide in one sentence, split it</p>
        </div>
      </li>
      <li>
        <div class="check">&#10003;</div>
        <div>
          <strong>Lead with the headline</strong>
          <p>The title should be the key takeaway, not a topic label</p>
        </div>
      </li>
      <li>
        <div class="check">&#10003;</div>
        <div>
          <strong>Let the slide breathe</strong>
          <p>Aim for 40-50% whitespace — remove everything that doesn't support the message</p>
        </div>
      </li>
      <li>
        <div class="check">&#10003;</div>
        <div>
          <strong>Show, don't tell</strong>
          <p>Replace paragraphs with charts, diagrams, or a single striking number</p>
        </div>
      </li>
    </ul>
  </div>
</SlideLayout>

<style>
  .takeaways {
    display: flex;
    flex-direction: column;
    height: 100%;
    padding-top: var(--space-lg);
  }

  h2 {
    font-size: var(--font-size-heading);
    font-weight: 700;
    color: var(--color-text);
    margin-bottom: var(--space-xl);
  }

  .takeaway-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
  }

  li {
    display: flex;
    align-items: flex-start;
    gap: var(--space-lg);
  }

  .check {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: var(--color-primary);
    color: white;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 20px;
    flex-shrink: 0;
    margin-top: 2px;
  }

  strong {
    font-size: var(--font-size-body);
    color: var(--color-text);
    display: block;
    margin-bottom: var(--space-xs);
  }

  p {
    font-size: 20px;
    color: var(--color-muted);
    line-height: 1.5;
  }
</style>
