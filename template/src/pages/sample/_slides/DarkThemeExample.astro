---
import SlideLayout from '../../../components/SlideLayout.astro';
---

<SlideLayout
  title="Dark Theme"
  theme="dark"
  pageNumber={8}
  transition="fade"
  notes="This slide demonstrates the dark theme. Note how all design tokens automatically adapt."
>
  <div class="content">
    <h2>Design Tokens Adapt Automatically</h2>
    <p class="subtitle">Switch between light and dark with a single prop</p>
    <div class="grid">
      <div class="card">
        <div class="card-icon">
          <svg viewBox="0 0 48 48" xmlns="http://www.w3.org/2000/svg">
            <circle cx="24" cy="24" r="18" fill="none" stroke="var(--color-chart-1)" stroke-width="2.5"/>
            <path d="M16 24 L22 30 L34 18" fill="none" stroke="var(--color-chart-1)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </div>
        <span class="card-title">CSS Custom Properties</span>
        <span class="card-desc">Colors, spacing, and typography all respond to the theme setting</span>
      </div>
      <div class="card">
        <div class="card-icon">
          <svg viewBox="0 0 48 48" xmlns="http://www.w3.org/2000/svg">
            <rect x="6" y="6" width="36" height="36" rx="8" fill="none" stroke="var(--color-chart-2)" stroke-width="2.5"/>
            <circle cx="24" cy="24" r="8" fill="var(--color-chart-2)" opacity="0.3"/>
            <circle cx="24" cy="24" r="4" fill="var(--color-chart-2)"/>
          </svg>
        </div>
        <span class="card-title">Consistent Contrast</span>
        <span class="card-desc">Dark theme provides WCAG-compliant contrast ratios out of the box</span>
      </div>
      <div class="card">
        <div class="card-icon">
          <svg viewBox="0 0 48 48" xmlns="http://www.w3.org/2000/svg">
            <path d="M24 6 L24 42 M6 24 L42 24" stroke="var(--color-chart-3)" stroke-width="2.5" stroke-linecap="round"/>
            <circle cx="24" cy="24" r="16" fill="none" stroke="var(--color-chart-3)" stroke-width="2.5"/>
          </svg>
        </div>
        <span class="card-title">Chart Colors Adjust</span>
        <span class="card-desc">All six chart colors are optimized for dark backgrounds</span>
      </div>
    </div>
  </div>
</SlideLayout>

<style>
  .content {
    display: flex;
    flex-direction: column;
    height: 100%;
    padding-top: var(--space-lg);
  }

  h2 {
    font-size: var(--font-size-heading);
    font-weight: 700;
    color: var(--color-text);
    margin-bottom: var(--space-sm);
  }

  .subtitle {
    font-size: var(--font-size-body);
    color: var(--color-muted);
    margin-bottom: var(--space-xl);
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-lg);
    flex: 1;
    align-content: center;
  }

  .card {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: var(--space-md);
    padding: var(--space-xl) var(--space-lg);
    border: 1px solid var(--color-border);
    border-radius: 16px;
  }

  .card-icon {
    width: 48px;
    height: 48px;
  }

  .card-title {
    font-size: var(--font-size-body);
    font-weight: 600;
    color: var(--color-text);
  }

  .card-desc {
    font-size: var(--font-size-caption);
    color: var(--color-muted);
    line-height: 1.5;
  }
</style>
