{
	"$schema": "https://biomejs.dev/schemas/2.4.7/schema.json",
	"vcs": {
		"clientKind": "git",
		"useIgnoreFile": true,
		"defaultBranch": "main"
	},
	"formatter": {
		"indentStyle": "tab",
		"lineWidth": 100
	},
	"linter": {
		"rules": {
			"recommended": true
		}
	},
	"assist": {
		"actions": {
			"source": {
				"organizeImports": "on"
			}
		}
	},
	"javascript": {
		"formatter": {
			"quoteStyle": "single",
			"semicolons": "always"
		}
	},
	"files": {
		"includes": [
			"template/**/*.ts",
			"template/**/*.mjs",
			"template/**/*.js",
			"template/**/*.json",
			"template/**/*.astro",
			"cli/**/*.ts",
			"cli/**/*.mjs",
			"cli/**/*.js",
			"!!**/node_modules",
			"!!**/dist",
			"!!**/.astro"
		]
	}
}
